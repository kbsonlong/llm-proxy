# ── 火山方舟 ──────────────────────────────────────────────────
VOLC_AK=AKLxxxxxxxxxxxxxxxxxxxx
VOLC_SK=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# litellm 实际调用的 Runtime API Key（与上方管控面 AK/SK 不同）
# 从火山方舟控制台 → API Key 管理获取
VOLCENGINE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── litellm ───────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-you...-key

# ── Token 限流配置 ───────────────────────────────────────────
TOKEN_TRACK_MODE=APPEND

# ── Docker 部署额外配置 ──────────────────────────────────────
# VOLC_REGION=cn-beijing
# TOKEN_DB_PATH=/var/lib/litellm/token_usage.json
# TOKEN_LIMITS_PATH=/app/token_limits.yaml
# DEFAULT_MODEL_LIMIT=1000000
